<!-- Toolbar: localized title, renderer/theme/locale toggles, toasts. -->
<Column flex col gap="3">
    <Row flex items_center gap="3">
        <Heading id="title" level="H1" text={controller.t("demo.title", cx)} />
    </Row>

    <Row flex items_center gap="2" flex_wrap>
        <ToggleButton id="renderer-default" caption={controller.t("demo.renderer_default", cx)}
                      selected={controller.current_renderer(cx) == crate::state::RendererKind::Default}
                      variant="primary"
                      on_toggle={{ let c = controller.clone(); move |_v,_ev,w,cx| c.set_renderer(crate::state::RendererKind::Default, w, cx) }} />
        <ToggleButton id="renderer-brutalism" caption={controller.t("demo.renderer_brutalism", cx)}
                      selected={controller.current_renderer(cx) == crate::state::RendererKind::Brutalism}
                      variant="primary"
                      on_toggle={{ let c = controller.clone(); move |_v,_ev,w,cx| c.set_renderer(crate::state::RendererKind::Brutalism, w, cx) }} />

        <ToggleButton id="dark-light" caption={controller.t("demo.theme_light", cx)}
                      selected={controller.dark_mode(cx) == crate::state::DarkMode::Light}
                      on_toggle={{ let c = controller.clone(); move |_v,_ev,w,cx| c.set_dark_mode(crate::state::DarkMode::Light, w, cx) }} />
        <ToggleButton id="dark-dark" caption={controller.t("demo.theme_dark", cx)}
                      selected={controller.dark_mode(cx) == crate::state::DarkMode::Dark}
                      on_toggle={{ let c = controller.clone(); move |_v,_ev,w,cx| c.set_dark_mode(crate::state::DarkMode::Dark, w, cx) }} />

        <ToggleButton id="locale-en" caption="EN"
                      selected={controller.current_locale(cx) == crate::state::LocaleChoice::En}
                      on_toggle={{ let c = controller.clone(); move |_v,_ev,w,cx| c.set_locale(crate::state::LocaleChoice::En, w, cx) }} />
        <ToggleButton id="locale-zh" caption="中文"
                      selected={controller.current_locale(cx) == crate::state::LocaleChoice::ZhCn}
                      on_toggle={{ let c = controller.clone(); move |_v,_ev,w,cx| c.set_locale(crate::state::LocaleChoice::ZhCn, w, cx) }} />
        <ToggleButton id="locale-ar" caption="العربية"
                      selected={controller.current_locale(cx) == crate::state::LocaleChoice::Ar}
                      on_toggle={{ let c = controller.clone(); move |_v,_ev,w,cx| c.set_locale(crate::state::LocaleChoice::Ar, w, cx) }} />

        <Div flex_1 />

        <Button id="show-toast" caption={controller.t("demo.show_toast", cx)}
                variant="danger"
                on_click={controller.show_toast} />
        <Button id="show-notification" caption={controller.t("demo.show_notification", cx)}
                variant="primary"
                on_click={controller.show_notification} />
    </Row>
</Column>
