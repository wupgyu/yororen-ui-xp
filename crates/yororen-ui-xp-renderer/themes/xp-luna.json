      "checkbox": { "size": 13, "radius": 0, "border_width": 1 },
      "radio": { "size": 13, "radius": 7, "border_width": 1 },
      "input": { "min_height": 23, "horizontal_padding": 4, "vertical_padding": 2, "radius": 0, "border_width": 1, "font_size": 13 },
