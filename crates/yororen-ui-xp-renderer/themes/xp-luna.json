      "modal": { "radius": 8, "border_width": 1, "padding": 12, "title_size": 13 },
      "popover": { "radius": 3, "border_width": 1, "padding": 8 },
      "dropdown_menu": { "radius": 3, "border_width": 1, "padding": 2 },
      "disclosure": { "radius": 0, "border_width": 1 },
      "toast": { "radius": 6, "border_width": 1, "padding": 10 },
      "notification": { "radius": 6, "border_width": 1, "padding": 12 },
      "panel": { "radius": 3, "border_width": 1, "padding": 12 },
      "card": { "radius": 3, "border_width": 1, "padding": 12 },
      "form": { "radius": 0, "border_width": 0, "padding": 12, "gap": 8 },
      "list_item": { "radius": 0, "border_width": 0, "padding": 4, "min_height": 24 },
