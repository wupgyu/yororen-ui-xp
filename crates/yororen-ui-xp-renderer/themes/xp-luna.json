      "tree": { "gap": 0, "border_width": 1, "padding": 2 },
      "table": { "cell_padding": 4, "header_font_size": 12, "row_font_size": 13, "border_width": 1 },
      "form_field": { "gap": 4, "label_font_size": 12 },
      "spacer": { "min_size": 0 },
      "icon": { "default_size": 16 },
      "text": { "default_size": 13 }
